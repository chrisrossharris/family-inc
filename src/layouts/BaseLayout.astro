---
import '@/styles/global.css';
import { REPORT_PERIOD } from '@/lib/constants';

interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Family Operating Dashboard</title>
  </head>
  <body>
    <main class="min-h-screen report-grid">
      <header class="border-b border-grid">
        <div class="mx-auto flex max-w-7xl flex-wrap items-end justify-between gap-4 px-4 py-6 md:px-8">
          <div>
            <p class="text-xs uppercase tracking-report text-muted">Family Operating Dashboard</p>
            <h1 class="text-2xl font-semibold tracking-tight">{title}</h1>
            {subtitle && <p class="mt-1 text-sm text-muted">{subtitle}</p>}
          </div>
          <div class="text-right">
            <p class="font-mono text-xs uppercase tracking-report text-muted">Period: {REPORT_PERIOD}</p>
            <p class="text-xs text-muted">Meals deductible at 50%</p>
          </div>
        </div>
        <nav class="mx-auto flex max-w-7xl flex-wrap gap-2 px-4 pb-4 md:px-8">
          <a class="border border-grid px-3 py-1 text-xs uppercase tracking-report hover:bg-ink hover:text-paper" href="/">Operating Report</a>
          <a class="border border-grid px-3 py-1 text-xs uppercase tracking-report hover:bg-ink hover:text-paper" href="/entity/chris">Chris</a>
          <a class="border border-grid px-3 py-1 text-xs uppercase tracking-report hover:bg-ink hover:text-paper" href="/entity/kate">Kate</a>
          <a class="border border-grid px-3 py-1 text-xs uppercase tracking-report hover:bg-ink hover:text-paper" href="/entity/big_picture">Big Picture</a>
          <a class="border border-grid px-3 py-1 text-xs uppercase tracking-report hover:bg-ink hover:text-paper" href="/needs-review">Needs Review</a>
          <a class="border border-grid px-3 py-1 text-xs uppercase tracking-report hover:bg-ink hover:text-paper" href="/deductions">Deductions</a>
        </nav>
      </header>
      <section class="mx-auto max-w-7xl px-4 py-6 md:px-8">
        <slot />
      </section>
    </main>
  </body>
</html>
