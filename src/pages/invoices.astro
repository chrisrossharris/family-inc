---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getInvoicesOverview } from '@/lib/services/invoices';
import { formatCurrency } from '@/lib/utils/format';
import { normalizeReportYear } from '@/lib/utils/year';

const tenantId = Astro.locals.tenantId;
const selectedYear = normalizeReportYear(Astro.url.searchParams.get('year'));
const saved = Astro.url.searchParams.get('saved');
const overview = await getInvoicesOverview(tenantId, selectedYear);
---

<BaseLayout title="Invoices & Receivables" subtitle="Track invoices, partial payments, overdue balances, and client exposure.">
  {saved && <div class="mb-4 border border-accent/40 bg-accent/10 p-3 text-sm">Saved: {saved}</div>}

  <section class="grid gap-4 md:grid-cols-3 lg:grid-cols-7">
    <article class="panel"><p class="panel-title">Invoices</p><p class="mono-num mt-2 text-2xl">{overview.stats.invoicesCount}</p></article>
    <article class="panel"><p class="panel-title">Total Invoiced</p><p class="mono-num mt-2 text-2xl">{formatCurrency(overview.stats.totalInvoiced)}</p></article>
    <article class="panel"><p class="panel-title">Total Paid</p><p class="mono-num mt-2 text-2xl">{formatCurrency(overview.stats.totalPaid)}</p></article>
    <article class="panel"><p class="panel-title">Outstanding</p><p class:list={['mono-num mt-2 text-2xl', overview.stats.totalOutstanding > 0 ? 'text-amber-900' : undefined]}>{formatCurrency(overview.stats.totalOutstanding)}</p></article>
    <article class="panel"><p class="panel-title">Overdue</p><p class:list={['mono-num mt-2 text-2xl', overview.stats.overdueCount > 0 ? 'text-red-700' : undefined]}>{overview.stats.overdueCount}</p></article>
    <article class="panel"><p class="panel-title">Partial</p><p class:list={['mono-num mt-2 text-2xl', overview.stats.partialCount > 0 ? 'text-amber-900' : undefined]}>{overview.stats.partialCount}</p></article>
    <article class="panel"><p class="panel-title">Due Soon</p><p class="mono-num mt-2 text-2xl">{overview.stats.dueSoon}</p></article>
  </section>

  <section class="mt-4 grid gap-4 lg:grid-cols-2">
    <article class="panel">
      <h2 class="panel-title">Add Invoice</h2>
      <details class="form-card mt-3" open={overview.invoices.length === 0}>
        <summary>New Invoice</summary>
        <form method="post" action="/api/invoices/invoice" class="mt-3 grid gap-2 md:grid-cols-2">
          <input type="hidden" name="year" value={selectedYear} />
          <input type="text" name="invoice_number" required placeholder="Invoice #" />
          <input type="text" name="client_name" required placeholder="Client" />
          <input type="text" name="project_name" placeholder="Project (optional)" />
          <select name="entity" required>
            <option value="chris">Chris</option>
            <option value="kate">Kate</option>
            <option value="big_picture" selected>Big Picture</option>
          </select>
          <input type="date" name="issued_on" required />
          <input type="date" name="due_on" required />
          <input type="number" name="amount_total" min="0.01" step="0.01" required placeholder="Amount total" />
          <select name="status">
            <option value="sent" selected>Sent</option>
            <option value="draft">Draft</option>
            <option value="paid">Paid</option>
            <option value="void">Void</option>
          </select>
          <textarea name="notes" rows="2" class="md:col-span-2" placeholder="Notes"></textarea>
          <button type="submit" class="md:col-span-2 border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Invoice</button>
        </form>
      </details>
    </article>

    <article class="panel">
      <h2 class="panel-title">Log Payment</h2>
      <p class="mt-2 text-xs text-muted">Use this for partial payments. Invoice status updates automatically.</p>
      <details class="form-card mt-3" open={overview.payments.length === 0 && overview.invoices.length > 0}>
        <summary>New Payment</summary>
        <form method="post" action="/api/invoices/payment" class="mt-3 grid gap-2 md:grid-cols-2">
          <input type="hidden" name="year" value={selectedYear} />
          <select name="invoice_id" required>
            {overview.invoices.length === 0 && <option value="">No invoices yet</option>}
            {overview.invoices.map((invoice) => (
              <option value={invoice.id}>{invoice.invoice_number} · {invoice.client_name} · {formatCurrency(invoice.amount_outstanding)} outstanding</option>
            ))}
          </select>
          <input type="date" name="received_on" required />
          <input type="number" name="amount" min="0.01" step="0.01" required placeholder="Payment amount" />
          <input type="text" name="method" placeholder="Method (ACH, wire, card)" />
          <input type="text" name="reference" placeholder="Reference #" class="md:col-span-2" />
          <textarea name="notes" rows="2" class="md:col-span-2" placeholder="Notes"></textarea>
          <button type="submit" class="md:col-span-2 border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Payment</button>
        </form>
      </details>
    </article>
  </section>

  <section class="mt-4 grid gap-4 lg:grid-cols-2">
    <article class="panel overflow-x-auto">
      <h2 class="panel-title">Invoice Ledger</h2>
      <table class="table-report mt-3 w-full min-w-[1140px]">
        <thead><tr><th>Invoice</th><th>Client</th><th>Entity</th><th>Due</th><th>Status</th><th class="text-right">Total</th><th class="text-right">Paid</th><th class="text-right">Outstanding</th><th>Stripe</th></tr></thead>
        <tbody>
          {overview.invoices.length === 0 && <tr><td colspan="9" class="text-xs text-muted">No invoices yet.</td></tr>}
          {overview.invoices.map((row) => (
            <tr>
              <td>{row.invoice_number}</td>
              <td>{row.client_name}{row.project_name ? ` · ${row.project_name}` : ''}</td>
              <td>{row.entity}</td>
              <td class:list={[row.status === 'overdue' ? 'text-red-700' : undefined]}>{row.due_on}</td>
              <td>{row.status}</td>
              <td class="mono-num">{formatCurrency(row.amount_total)}</td>
              <td class="mono-num">{formatCurrency(row.amount_paid)}</td>
              <td class:list={['mono-num', row.amount_outstanding > 0 ? 'text-amber-900' : undefined]}>{formatCurrency(row.amount_outstanding)}</td>
              <td>
                {row.amount_outstanding > 0 && row.status !== 'void' ? (
                  <form method="post" action="/api/invoices/create-checkout">
                    <input type="hidden" name="year" value={selectedYear} />
                    <input type="hidden" name="invoice_id" value={row.id} />
                    <button type="submit" class="border border-grid px-2 py-1 text-[10px] uppercase tracking-report hover:bg-ink hover:text-paper">Pay</button>
                  </form>
                ) : (
                  <span class="text-[10px] text-muted">—</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>

    <article class="panel overflow-x-auto">
      <h2 class="panel-title">Payments + Client Exposure</h2>
      <table class="table-report mt-3 w-full">
        <thead><tr><th>Date</th><th>Invoice</th><th>Client</th><th class="text-right">Amount</th><th>Income Sync</th></tr></thead>
        <tbody>
          {overview.payments.length === 0 && <tr><td colspan="5" class="text-xs text-muted">No payments logged yet.</td></tr>}
          {overview.payments.slice(0, 20).map((row) => (
            <tr>
              <td>{row.received_on}</td>
              <td>{row.invoice_number}</td>
              <td>{row.client_name}</td>
              <td class="mono-num">{formatCurrency(row.amount)}</td>
              <td>
                {row.income_receipt_id ? (
                  <span class="inline-block border border-grid px-2 py-1 text-[10px] uppercase tracking-report">Synced</span>
                ) : (
                  <form method="post" action="/api/invoices/payment-to-income">
                    <input type="hidden" name="year" value={selectedYear} />
                    <input type="hidden" name="payment_id" value={row.id} />
                    <button type="submit" class="border border-grid px-2 py-1 text-[10px] uppercase tracking-report hover:bg-ink hover:text-paper">Sync</button>
                  </form>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>

      <h3 class="panel-title mt-5">Top Clients</h3>
      <table class="table-report mt-3 w-full">
        <thead><tr><th>Client</th><th class="text-right">Invoiced</th></tr></thead>
        <tbody>
          {overview.topClients.length === 0 && <tr><td colspan="2" class="text-xs text-muted">No client exposure yet.</td></tr>}
          {overview.topClients.map((row) => (
            <tr>
              <td>{row.client_name}</td>
              <td class="mono-num">{formatCurrency(row.total)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>
  </section>

  <footer class="mt-6 border-t border-grid pt-4 text-xs text-muted">
    <p>Receivables exports for {selectedYear}:</p>
    <div class="mt-2 flex flex-wrap gap-2">
      <a href={`/api/exports/invoices-ledger.csv?year=${selectedYear}`} class="border border-grid px-2 py-1 hover:bg-ink hover:text-paper">Invoices Ledger CSV</a>
      <a href={`/api/exports/invoice-payments.csv?year=${selectedYear}`} class="border border-grid px-2 py-1 hover:bg-ink hover:text-paper">Invoice Payments CSV</a>
    </div>
  </footer>
</BaseLayout>
