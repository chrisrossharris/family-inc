---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { listInvitations, listMembers } from '@/lib/services/members';

const tenantId = Astro.locals.tenantId;
const members = await listMembers(tenantId);
const invitations = await listInvitations(tenantId);
const invited = Astro.url.searchParams.get('invited');
const inviteEmail = Astro.url.searchParams.get('inviteEmail');
const inviteError = Astro.url.searchParams.get('inviteError');
const updated = Astro.url.searchParams.get('updated');
const removed = Astro.url.searchParams.get('removed');
const error = Astro.url.searchParams.get('error');
---

<BaseLayout title="Family Members" subtitle="Invite and manage shared access.">
  {invited && <div class="mb-4 border border-accent/40 bg-accent/10 p-3 text-sm">Invitation queued for {invited}.</div>}
  {invited && inviteEmail === 'sent' && <div class="mb-4 border border-accent/40 bg-accent/10 p-3 text-sm">Invite email sent to {invited}.</div>}
  {invited && inviteEmail === 'failed' && <div class="mb-4 border border-amber-300 bg-amber-50 p-3 text-sm text-amber-900">Invite saved but email was not sent. {inviteError ? `Reason: ${inviteError}` : 'Check `RESEND_API_KEY` and `INVITE_FROM_EMAIL`.'}</div>}
  {updated && <div class="mb-4 border border-accent/40 bg-accent/10 p-3 text-sm">Updated member role: {updated}</div>}
  {removed && <div class="mb-4 border border-accent/40 bg-accent/10 p-3 text-sm">Removed member: {removed}</div>}
  {error === 'last-owner' && <div class="mb-4 border border-red-300 bg-red-50 p-3 text-sm text-red-900">Cannot demote the last owner. Assign another owner first.</div>}

  <section class="panel">
    <h2 class="panel-title">Invite Family Member</h2>
    <form method="post" action="/api/members/invite" class="mt-3 grid gap-3 md:grid-cols-4">
      <input type="hidden" name="returnTo" value="/members" />
      <input type="email" name="email" required placeholder="email@family.com" class="md:col-span-2" />
      <select name="role">
        <option value="owner">Owner</option>
        <option value="admin">Admin</option>
        <option value="editor" selected>Editor</option>
        <option value="viewer">Viewer</option>
      </select>
      <button type="submit" class="border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Send Invite</button>
    </form>
  </section>

  <section class="panel mt-4 overflow-x-auto">
    <h2 class="panel-title">Current Members</h2>
    <p class="mt-2 text-xs text-muted">You can update access role directly per member.</p>
    <table class="table-report mt-3 w-full min-w-[820px]">
      <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Edit</th><th>Remove</th></tr></thead>
      <tbody>
        {members.length === 0 && <tr><td colspan="5" class="text-xs text-muted">No members yet.</td></tr>}
        {members.map((member, index) => (
          <tr>
            <td>{member.display_name}</td>
            <td>{member.email}</td>
            <td>
              <select form={`member-role-${index}`} name="role" class="text-xs uppercase tracking-report">
                <option value="owner" selected={member.role === 'owner'}>owner</option>
                <option value="admin" selected={member.role === 'admin'}>admin</option>
                <option value="editor" selected={member.role === 'editor'}>editor</option>
                <option value="viewer" selected={member.role === 'viewer'}>viewer</option>
              </select>
            </td>
            <td>
              <button form={`member-role-${index}`} type="submit" class="border border-grid px-2 py-1 text-[10px] uppercase tracking-report hover:bg-ink hover:text-paper">
                Save
              </button>
              <form id={`member-role-${index}`} method="post" action="/api/members/update-role" class="hidden">
                <input type="hidden" name="user_id" value={member.user_id} />
                <input type="hidden" name="returnTo" value="/members" />
              </form>
            </td>
            <td>
              <form method="post" action="/api/members/remove" onsubmit="return confirm('Remove this member from workspace access?');">
                <input type="hidden" name="user_id" value={member.user_id} />
                <input type="hidden" name="returnTo" value="/members" />
                <button type="submit" class="border border-red-500 px-2 py-1 text-[10px] uppercase tracking-report text-red-700 hover:bg-red-600 hover:text-paper">
                  Remove
                </button>
              </form>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="panel mt-4 overflow-x-auto">
    <h2 class="panel-title">Pending Invitations</h2>
    <table class="table-report mt-3 w-full min-w-[700px]">
      <thead><tr><th>Email</th><th>Role</th><th>Status</th><th>Created</th></tr></thead>
      <tbody>
        {invitations.map((invite) => (
          <tr>
            <td>{invite.email}</td>
            <td class="uppercase tracking-report text-xs">{invite.role}</td>
            <td>{invite.status}</td>
            <td class="font-mono text-xs">{invite.created_at}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>
