---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { normalizeReportYear } from '@/lib/utils/year';
import { getGoalsProjectsOverview } from '@/lib/services/pillars';

const tenantId = Astro.locals.tenantId;
const selectedYear = normalizeReportYear(Astro.url.searchParams.get('year'));
const saved = Astro.url.searchParams.get('saved');
const overview = await getGoalsProjectsOverview(tenantId, selectedYear);
const todayIso = new Date().toISOString().slice(0, 10);
const overdueProjects = overview.projects.filter((p) => p.status !== 'completed' && p.due_date && p.due_date < todayIso);
const highPriorityActiveProjects = overview.projects.filter((p) => p.status === 'active' && p.priority === 'high');
const overdueGoals = overview.goals.filter((g) => g.status !== 'completed' && g.target_date && g.target_date < todayIso);
const stalledGoals = overview.goals.filter((g) => g.status === 'active' && g.progress_pct < 25);
---

<BaseLayout title="Goals & Projects" subtitle="Practical execution board for family initiatives and long-horizon goals.">
  {saved && <div class="mb-4 border border-accent/40 bg-accent/10 p-3 text-sm">Saved: {saved}</div>}

  <section class="kpi-grid md:grid-cols-4 2xl:grid-cols-7">
    <article class="kpi-card"><p class="panel-title">Projects</p><p class="kpi-value">{overview.stats.projects}</p></article>
    <article class="kpi-card"><p class="panel-title">Active Projects</p><p class="kpi-value">{overview.stats.activeProjects}</p></article>
    <article class="kpi-card"><p class="panel-title">Overdue Projects</p><p class="kpi-value">{overdueProjects.length}</p></article>
    <article class="kpi-card"><p class="panel-title">High Priority Active</p><p class="kpi-value">{highPriorityActiveProjects.length}</p></article>
    <article class="kpi-card"><p class="panel-title">Goals</p><p class="kpi-value">{overview.stats.goals}</p></article>
    <article class="kpi-card"><p class="panel-title">Goals Due {selectedYear}</p><p class="kpi-value">{overview.stats.goalsDueThisYear}</p></article>
    <article class="kpi-card"><p class="panel-title">On-Track Goals</p><p class="kpi-value">{overview.stats.onTrackGoals}</p></article>
  </section>

  <section class="panel mt-4">
    <h2 class="panel-title">Operational Focus</h2>
    <div class="mt-2 flex flex-wrap gap-2">
      <span class:list={['inline-block border px-2 py-1 text-[10px] uppercase tracking-report', overdueProjects.length > 0 ? 'border-red-300 bg-red-50 text-red-900' : 'border-grid']}>
        Overdue Projects: {overdueProjects.length}
      </span>
      <span class:list={['inline-block border px-2 py-1 text-[10px] uppercase tracking-report', overdueGoals.length > 0 ? 'border-red-300 bg-red-50 text-red-900' : 'border-grid']}>
        Overdue Goals: {overdueGoals.length}
      </span>
      <span class:list={['inline-block border px-2 py-1 text-[10px] uppercase tracking-report', stalledGoals.length > 0 ? 'border-amber-300 bg-amber-50 text-amber-900' : 'border-grid']}>
        Stalled Goals (&lt;25%): {stalledGoals.length}
      </span>
    </div>
    {(overdueProjects.length > 0 || overdueGoals.length > 0) && (
      <div class="mt-3 grid gap-2 md:grid-cols-2 text-xs">
        <div class="border border-grid p-2">
          <p class="panel-title">Project Attention</p>
          {overdueProjects.length === 0 ? (
            <p class="mt-1 text-muted">No overdue projects.</p>
          ) : (
            <ul class="mt-1 space-y-1">
              {overdueProjects.slice(0, 4).map((p) => <li>{p.title} ({p.due_date})</li>)}
            </ul>
          )}
        </div>
        <div class="border border-grid p-2">
          <p class="panel-title">Goal Attention</p>
          {overdueGoals.length === 0 ? (
            <p class="mt-1 text-muted">No overdue goals.</p>
          ) : (
            <ul class="mt-1 space-y-1">
              {overdueGoals.slice(0, 4).map((g) => <li>{g.goal_title} ({g.target_date})</li>)}
            </ul>
          )}
        </div>
      </div>
    )}
  </section>

  <section class="mt-4 grid gap-4 lg:grid-cols-2">
    <article class="panel">
      <h2 class="panel-title">Projects</h2>
      <p class="mt-2 text-xs text-muted">{overview.projects.length === 0 ? 'No projects yet.' : `${overview.projects.length} projects tracked.`}</p>
      <details class="form-card mt-3" open={overview.projects.length === 0}>
        <summary>Add Project</summary>
        <form method="post" action="/api/pillars/project" class="mt-3 grid gap-2 md:grid-cols-2">
          <input type="hidden" name="year" value={selectedYear} />
          <input type="text" name="title" required placeholder="Project title" class="md:col-span-2" />
          <input type="text" name="owner_name" placeholder="Owner" />
          <select name="priority"><option value="low">Low</option><option value="medium" selected>Medium</option><option value="high">High</option></select>
          <select name="status"><option value="active">Active</option><option value="on_hold">On Hold</option><option value="completed">Completed</option></select>
          <input type="date" name="due_date" />
          <textarea name="notes" rows="2" class="md:col-span-2" placeholder="Notes"></textarea>
          <button type="submit" class="md:col-span-2 border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Project</button>
        </form>
      </details>
      <div class="mt-3 space-y-3 md:hidden">
        {overview.projects.length === 0 && <div class="border border-grid p-3 text-xs text-muted">No projects yet. Add first project above.</div>}
        {overview.projects.map((row) => (
          <form method="post" action="/api/pillars/project" class="mobile-edit-card">
            <input type="hidden" name="year" value={selectedYear} />
            <input type="hidden" name="id" value={row.id} />
            <input type="hidden" name="notes" value={row.notes ?? ''} />
            <label class="mobile-edit-label">Title<input type="text" name="title" required value={row.title} class="mt-1" /></label>
            <label class="mobile-edit-label">Owner<input type="text" name="owner_name" value={row.owner_name ?? ''} class="mt-1" /></label>
            <div class="grid grid-cols-2 gap-2">
              <label class="mobile-edit-label">Status
                <select name="status" class="mt-1">
                  <option value="active" selected={row.status === 'active'}>active</option>
                  <option value="on_hold" selected={row.status === 'on_hold'}>on_hold</option>
                  <option value="completed" selected={row.status === 'completed'}>completed</option>
                </select>
              </label>
              <label class="mobile-edit-label">Priority
                <select name="priority" class="mt-1">
                  <option value="low" selected={row.priority === 'low'}>low</option>
                  <option value="medium" selected={row.priority === 'medium'}>medium</option>
                  <option value="high" selected={row.priority === 'high'}>high</option>
                </select>
              </label>
            </div>
            <label class="mobile-edit-label">Due Date<input type="date" name="due_date" value={row.due_date ?? ''} class="mt-1" /></label>
            <div class="mobile-edit-actions flex justify-end"><button type="submit" class="border border-grid px-3 py-1.5 text-[10px] uppercase tracking-report hover:bg-ink hover:text-paper">Save</button></div>
          </form>
        ))}
      </div>
      <div class="overflow-x-auto">
      <table class="table-report mt-4 w-full min-w-[980px] hidden md:table">
        <thead><tr><th>Title</th><th>Owner</th><th>Status</th><th>Priority</th><th>Due</th><th>Edit</th></tr></thead>
        <tbody>
          {overview.projects.length === 0 && <tr><td colspan="6" class="text-xs text-muted">No projects yet. Add first project above.</td></tr>}
          {overview.projects.map((row) => (
            <tr>
              <td><input form={`project-edit-${row.id}`} type="text" name="title" required value={row.title} class="text-xs" /></td>
              <td><input form={`project-edit-${row.id}`} type="text" name="owner_name" value={row.owner_name ?? ''} class="text-xs" /></td>
              <td>
                <select form={`project-edit-${row.id}`} name="status" class="text-xs">
                  <option value="active" selected={row.status === 'active'}>active</option>
                  <option value="on_hold" selected={row.status === 'on_hold'}>on_hold</option>
                  <option value="completed" selected={row.status === 'completed'}>completed</option>
                </select>
              </td>
              <td>
                <select form={`project-edit-${row.id}`} name="priority" class="text-xs">
                  <option value="low" selected={row.priority === 'low'}>low</option>
                  <option value="medium" selected={row.priority === 'medium'}>medium</option>
                  <option value="high" selected={row.priority === 'high'}>high</option>
                </select>
              </td>
              <td class:list={[row.due_date && row.due_date < todayIso && row.status !== 'completed' ? 'text-red-700' : undefined]}>
                <input form={`project-edit-${row.id}`} type="date" name="due_date" value={row.due_date ?? ''} class="text-xs" />
              </td>
              <td>
                <button form={`project-edit-${row.id}`} type="submit" class="border border-grid px-2 py-1 text-[10px] uppercase tracking-report hover:bg-ink hover:text-paper">Save</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      </div>
      {overview.projects.map((row) => (
        <form id={`project-edit-${row.id}`} method="post" action="/api/pillars/project" class="hidden">
          <input type="hidden" name="year" value={selectedYear} />
          <input type="hidden" name="id" value={row.id} />
          <input type="hidden" name="notes" value={row.notes ?? ''} />
        </form>
      ))}
    </article>

    <article class="panel">
      <h2 class="panel-title">Goals</h2>
      <p class="mt-2 text-xs text-muted">{overview.goals.length === 0 ? 'No goals yet.' : `${overview.goals.length} goals tracked.`}</p>
      <details class="form-card mt-3" open={overview.goals.length === 0}>
        <summary>Add Goal</summary>
        <form method="post" action="/api/pillars/goal" class="mt-3 grid gap-2 md:grid-cols-2">
          <input type="hidden" name="year" value={selectedYear} />
          <input type="text" name="goal_title" required placeholder="Goal title" class="md:col-span-2" />
          <input type="text" name="domain" required placeholder="Domain" />
          <input type="date" name="target_date" />
          <input type="number" name="progress_pct" min="0" max="100" placeholder="Progress %" />
          <select name="status"><option value="active">Active</option><option value="on_hold">On Hold</option><option value="completed">Completed</option></select>
          <textarea name="notes" rows="2" class="md:col-span-2" placeholder="Notes"></textarea>
          <button type="submit" class="md:col-span-2 border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Goal</button>
        </form>
      </details>
      <div class="mt-3 space-y-3 md:hidden">
        {overview.goals.length === 0 && <div class="border border-grid p-3 text-xs text-muted">No goals yet. Add first goal above.</div>}
        {overview.goals.map((row) => (
          <form method="post" action="/api/pillars/goal" class="mobile-edit-card">
            <input type="hidden" name="year" value={selectedYear} />
            <input type="hidden" name="id" value={row.id} />
            <input type="hidden" name="notes" value={row.notes ?? ''} />
            <label class="mobile-edit-label">Goal<input type="text" name="goal_title" required value={row.goal_title} class="mt-1" /></label>
            <label class="mobile-edit-label">Domain<input type="text" name="domain" required value={row.domain} class="mt-1" /></label>
            <div class="grid grid-cols-2 gap-2">
              <label class="mobile-edit-label">Progress %
                <input type="number" min="0" max="100" name="progress_pct" value={row.progress_pct} class="mt-1 text-right" />
              </label>
              <label class="mobile-edit-label">Status
                <select name="status" class="mt-1">
                  <option value="active" selected={row.status === 'active'}>active</option>
                  <option value="on_hold" selected={row.status === 'on_hold'}>on_hold</option>
                  <option value="completed" selected={row.status === 'completed'}>completed</option>
                </select>
              </label>
            </div>
            <label class="mobile-edit-label">Target Date<input type="date" name="target_date" value={row.target_date ?? ''} class="mt-1" /></label>
            <div class="mobile-edit-actions flex justify-end"><button type="submit" class="border border-grid px-3 py-1.5 text-[10px] uppercase tracking-report hover:bg-ink hover:text-paper">Save</button></div>
          </form>
        ))}
      </div>
      <div class="overflow-x-auto">
      <table class="table-report mt-4 w-full min-w-[980px] hidden md:table">
        <thead><tr><th>Goal</th><th>Domain</th><th class="text-right">Progress</th><th>Status</th><th>Target</th><th>Edit</th></tr></thead>
        <tbody>
          {overview.goals.length === 0 && <tr><td colspan="6" class="text-xs text-muted">No goals yet. Add first goal above.</td></tr>}
          {overview.goals.map((row) => (
            <tr>
              <td><input form={`goal-edit-${row.id}`} type="text" name="goal_title" required value={row.goal_title} class="text-xs" /></td>
              <td><input form={`goal-edit-${row.id}`} type="text" name="domain" required value={row.domain} class="text-xs" /></td>
              <td class:list={['mono-num', row.status === 'active' && row.progress_pct < 25 ? 'text-amber-900' : undefined]}>
                <input form={`goal-edit-${row.id}`} type="number" min="0" max="100" name="progress_pct" value={row.progress_pct} class="w-20 text-right text-xs" />
              </td>
              <td>
                <select form={`goal-edit-${row.id}`} name="status" class="text-xs">
                  <option value="active" selected={row.status === 'active'}>active</option>
                  <option value="on_hold" selected={row.status === 'on_hold'}>on_hold</option>
                  <option value="completed" selected={row.status === 'completed'}>completed</option>
                </select>
              </td>
              <td class:list={[row.target_date && row.target_date < todayIso && row.status !== 'completed' ? 'text-red-700' : undefined]}>
                <input form={`goal-edit-${row.id}`} type="date" name="target_date" value={row.target_date ?? ''} class="text-xs" />
              </td>
              <td>
                <button form={`goal-edit-${row.id}`} type="submit" class="border border-grid px-2 py-1 text-[10px] uppercase tracking-report hover:bg-ink hover:text-paper">Save</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      </div>
      {overview.goals.map((row) => (
        <form id={`goal-edit-${row.id}`} method="post" action="/api/pillars/goal" class="hidden">
          <input type="hidden" name="year" value={selectedYear} />
          <input type="hidden" name="id" value={row.id} />
          <input type="hidden" name="notes" value={row.notes ?? ''} />
        </form>
      ))}
    </article>
  </section>
</BaseLayout>
