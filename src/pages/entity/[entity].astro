---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SCHEDULE_C_CATEGORIES } from '@/lib/constants';
import { listFinanceEntityOptions } from '@/lib/services/finance-entities';
import { getCategoryDistribution, getEntityLedger, getEntityMonthlyCategoryMatrix, getTopVendors } from '@/lib/services/reports';
import { formatCurrency } from '@/lib/utils/format';
import { normalizeReportYear } from '@/lib/utils/year';

const entity = String(Astro.params.entity ?? '').trim();
const tenantId = Astro.locals.tenantId;
const entityOptions = await listFinanceEntityOptions(tenantId);
const entityMeta = entityOptions.find((item) => item.code === entity);
if (!entity || !entityMeta) {
  return Astro.redirect('/');
}

const selectedYear = normalizeReportYear(Astro.url.searchParams.get('year'));
const updatedRows = Astro.url.searchParams.get('updated');
const categoryRows = await getCategoryDistribution(tenantId, entity, selectedYear);
const vendorRows = await getTopVendors(tenantId, entity, 15, selectedYear);
const ledgerRows = await getEntityLedger(tenantId, entity, undefined, selectedYear);
const monthlyMatrix = await getEntityMonthlyCategoryMatrix(tenantId, entity, selectedYear);
const total = categoryRows.reduce((acc, row) => acc + row.total, 0);
const monthColumns = Array.from({ length: 12 }, (_, index) => {
  const month = `${selectedYear}-${String(index + 1).padStart(2, '0')}`;
  const label = new Date(`${month}-01T00:00:00`).toLocaleString('en-US', { month: 'long' });
  return { month, label };
});
const monthlyTotals = monthColumns.map((column) => ({
  month: column.month,
  total: monthlyMatrix.reduce((sum, row) => sum + (row.months.find((entry) => entry.month === column.month)?.total ?? 0), 0)
}));
---

<BaseLayout title={`${entityMeta.label} Detail`} subtitle="Entity operating ledger and controls.">
  {updatedRows && (
    <div class="mb-4 border border-accent/40 bg-accent/10 p-3 text-sm">
      Updated {updatedRows} transaction{updatedRows === '1' ? '' : 's'}.
    </div>
  )}

  <section class="grid gap-4 lg:grid-cols-2">
    <article class="panel">
      <h2 class="panel-title">Category Table</h2>
      <table class="table-report mt-3 w-full">
        <thead><tr><th>Category</th><th class="text-right">Total</th><th class="text-right">%</th></tr></thead>
        <tbody>
          {categoryRows.map((row) => (
            <tr>
              <td>{row.category}</td>
              <td class="mono-num">{formatCurrency(row.total)}</td>
              <td class="mono-num">{total > 0 ? `${((row.total / total) * 100).toFixed(1)}%` : '0.0%'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>

    <article class="panel">
      <h2 class="panel-title">Vendor Leaderboard</h2>
      <table class="table-report mt-3 w-full">
        <thead><tr><th>Vendor</th><th class="text-right">Total</th></tr></thead>
        <tbody>
          {vendorRows.map((row) => (
            <tr>
              <td>{row.vendor}</td>
              <td class="mono-num">{formatCurrency(row.total)}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <a class="mt-4 inline-block border border-grid px-3 py-1 text-xs uppercase tracking-report" href={`/api/exports/${entity}.csv?year=${selectedYear}`}>Export {entityMeta.label} CSV</a>
    </article>
  </section>

  <section class="panel mt-4 overflow-x-auto">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h2 class="panel-title">Monthly Expense Matrix</h2>
        <p class="mt-2 text-xs text-muted">Expenses are shown by payment month for {entityMeta.label}. This is the worksheet view for annual tax review and planning.</p>
      </div>
      <p class="text-[10px] uppercase tracking-report text-muted">Cash basis view • {selectedYear}</p>
    </div>
    <table class="table-report mt-4 w-full min-w-[1400px]">
      <thead>
        <tr>
          <th>Business Expense Category</th>
          {monthColumns.map((column) => <th class="text-right">{column.label}</th>)}
          <th class="text-right">Totals</th>
        </tr>
      </thead>
      <tbody>
        {monthlyMatrix.length === 0 && <tr><td colspan={14} class="text-xs text-muted">No categorized business expenses for this entity and year yet.</td></tr>}
        {monthlyMatrix.map((row) => (
          <tr>
            <td>{row.category}</td>
            {monthColumns.map((column) => {
              const amount = row.months.find((entry) => entry.month === column.month)?.total ?? 0;
              return <td class="mono-num">{amount > 0 ? formatCurrency(amount) : '—'}</td>;
            })}
            <td class="mono-num font-semibold">{formatCurrency(row.total)}</td>
          </tr>
        ))}
        {monthlyMatrix.length > 0 && (
          <tr>
            <td class="font-semibold">Total</td>
            {monthlyTotals.map((column) => <td class="mono-num font-semibold">{column.total > 0 ? formatCurrency(column.total) : formatCurrency(0)}</td>)}
            <td class="mono-num font-semibold">{formatCurrency(monthlyTotals.reduce((sum, column) => sum + column.total, 0))}</td>
          </tr>
        )}
      </tbody>
    </table>
  </section>

  <section class="panel mt-4">
    <h2 class="panel-title">Bulk Edit</h2>
    <form method="post" action="/api/transactions-bulk-update" class="mt-3 grid gap-3 md:grid-cols-3">
      <textarea name="ids" required placeholder="IDs (comma-separated)" class="md:col-span-2"></textarea>
      <input type="hidden" name="entity" value={entity} />
      <select name="category" class="md:col-span-2">
        {SCHEDULE_C_CATEGORIES.map((cat) => <option value={cat}>{cat}</option>)}
      </select>
      <button type="submit" class="border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Update Selected</button>
    </form>
  </section>

  <section class="panel mt-4 overflow-x-auto">
    <h2 class="panel-title">Transaction Ledger</h2>
    <form method="post" action="/api/transactions-grid-update">
      <input type="hidden" name="ids" value={ledgerRows.map((row) => row.id).join(',')} />
      <p class="mb-2 text-[10px] uppercase tracking-report text-muted">Edit multiple rows, then press Enter in any field to save all.</p>
      <table class="table-report mt-3 w-full min-w-[1200px]">
        <thead>
          <tr><th>ID</th><th>Date</th><th>Vendor</th><th>Description</th><th>Account</th><th>Entity</th><th>Category</th><th>Confidence</th><th class="text-right">Amount</th></tr>
        </thead>
        <tbody>
          {ledgerRows.map((row) => (
            <tr>
              <td class="mono-num">{row.id}</td>
              <td>{row.date}</td>
              <td>
                <input name={`vendor_${row.id}`} value={row.vendor} class="text-xs" title="Press Enter to save all edits" />
              </td>
              <td><input name={`description_${row.id}`} value={row.description ?? ''} class="text-xs" title="Press Enter to save all edits" /></td>
              <td>{row.account}</td>
              <td>
                <select name={`entity_${row.id}`} class="text-xs">
                  {entityOptions.map((option) => <option value={option.code} selected={row.entity === option.code}>{option.label}</option>)}
                </select>
              </td>
              <td>
                <select name={`category_${row.id}`} class="text-xs">
                  {SCHEDULE_C_CATEGORIES.map((cat) => <option value={cat} selected={row.category === cat}>{cat}</option>)}
                </select>
              </td>
              <td>{row.confidence}</td>
              <td class="mono-num">{formatCurrency(row.amount)}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <button type="submit" class="sr-only">Save all edits</button>
    </form>
  </section>
</BaseLayout>
