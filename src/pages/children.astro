---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { normalizeReportYear } from '@/lib/utils/year';
import { getChildrenOverview, listChildrenMembers } from '@/lib/services/children';

const tenantId = Astro.locals.tenantId;
const selectedYear = normalizeReportYear(Astro.url.searchParams.get('year'));
const saved = Astro.url.searchParams.get('saved');
const members = await listChildrenMembers(tenantId);
const overview = await getChildrenOverview(tenantId, selectedYear);

const completionPct = overview.stats.totalGoals > 0 ? (overview.stats.onTrackGoals / overview.stats.totalGoals) * 100 : 0;
const profileCount = overview.snapshots.filter((row) => row.profile).length;
const checkinCount = overview.snapshots.reduce((acc, row) => acc + row.checkins, 0);
const goalsCount = overview.goals.length;
const milestonesCount = overview.milestones.length;
const academicsCount = overview.academics.length;
const activitiesCount = overview.activities.length;
const contactsCount = overview.contacts.length;
---

<BaseLayout title="Children" subtitle="Whole-child operating view for academics, wellness, goals, activities, and support network.">
  {saved && <div class="mb-4 border border-accent/40 bg-accent/10 p-3 text-sm">Saved: {saved}</div>}

  {members.length === 0 && (
    <section class="panel mb-4">
      <p class="panel-title">No Child Members Found</p>
      <p class="mt-2 text-sm text-muted">
        Add children in the Health workspace Family Members panel using relations like <strong>child</strong>, <strong>son</strong>, or <strong>daughter</strong>.
      </p>
      <a class="mt-3 inline-block border border-grid px-3 py-1 text-xs uppercase tracking-report hover:bg-ink hover:text-paper" href={`/health?year=${selectedYear}#members`}>
        Open Family Members
      </a>
    </section>
  )}

  <section class="grid gap-4 md:grid-cols-3 xl:grid-cols-6">
    <article class="panel"><p class="panel-title">Children Tracked</p><p class="mono-num mt-2 text-2xl">{overview.stats.childrenCount}</p></article>
    <article class="panel"><p class="panel-title">Active Goals</p><p class="mono-num mt-2 text-2xl">{overview.stats.totalGoals}</p></article>
    <article class="panel"><p class="panel-title">On-Track Goals</p><p class="mono-num mt-2 text-2xl">{overview.stats.onTrackGoals}</p><p class="text-xs text-muted">{completionPct.toFixed(1)}% on track</p></article>
    <article class="panel"><p class="panel-title">Milestones ({selectedYear})</p><p class="mono-num mt-2 text-2xl">{overview.stats.milestonesCount}</p></article>
    <article class="panel"><p class="panel-title">Support Contacts</p><p class="mono-num mt-2 text-2xl">{overview.stats.contactsCount}</p></article>
    <article class="panel"><p class="panel-title">Check-in Entries ({selectedYear})</p><p class="mono-num mt-2 text-2xl">{overview.snapshots.reduce((acc, row) => acc + row.checkins, 0)}</p></article>
  </section>

  <section class="panel mt-4 overflow-x-auto">
    <h2 class="panel-title">Child Snapshot</h2>
    <table class="table-report mt-3 w-full min-w-[960px]">
      <thead><tr><th>Child</th><th>Grade</th><th>School</th><th class="text-right">Avg Mood</th><th class="text-right">Avg Sleep</th><th class="text-right">Reading</th><th class="text-right">Active Goals</th><th class="text-right">On Track</th></tr></thead>
      <tbody>
        {overview.snapshots.map((row) => (
          <tr>
            <td class="font-medium">{row.child.name}</td>
            <td>{row.profile?.grade_level ?? '—'}</td>
            <td>{row.profile?.school_name ?? '—'}</td>
            <td class="mono-num">{row.avgMood.toFixed(1)}</td>
            <td class="mono-num">{row.avgSleep.toFixed(1)}h</td>
            <td class="mono-num">{Math.round(row.avgReading)}m</td>
            <td class="mono-num">{row.activeGoals}</td>
            <td class="mono-num">{row.onTrackGoals}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="mt-4 grid gap-4 lg:grid-cols-2">
    <article class="panel">
      <h2 class="panel-title">Profile & Learning Context</h2>
      <p class="mt-2 text-xs text-muted">{profileCount} child profile{profileCount === 1 ? '' : 's'} on file.</p>
      <details class="form-card mt-3" open={profileCount === 0}>
        <summary>Add or Update Profile</summary>
        <form method="post" action="/api/children/profile" class="mt-3 grid gap-2 md:grid-cols-2">
          <input type="hidden" name="year" value={selectedYear} />
          <select name="member_id" required>{members.map((m) => <option value={m.id}>{m.name}</option>)}</select>
          <input type="text" name="grade_level" placeholder="Grade level" />
          <input type="text" name="school_name" placeholder="School" class="md:col-span-2" />
          <input type="text" name="learning_style" placeholder="Learning style" class="md:col-span-2" />
          <textarea name="strengths" rows="2" placeholder="Strengths" class="md:col-span-2"></textarea>
          <textarea name="support_needs" rows="2" placeholder="Support needs" class="md:col-span-2"></textarea>
          <textarea name="long_term_focus" rows="2" placeholder="Long-term focus" class="md:col-span-2"></textarea>
          <button type="submit" class="md:col-span-2 border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Profile</button>
        </form>
      </details>
    </article>

    <article class="panel">
      <h2 class="panel-title">Daily Check-In</h2>
      <p class="mt-2 text-xs text-muted">{checkinCount} check-ins logged this year.</p>
      <details class="form-card mt-3" open={checkinCount === 0}>
        <summary>Add Daily Check-In</summary>
        <form method="post" action="/api/children/checkin" class="mt-3 grid gap-2 md:grid-cols-2">
          <input type="hidden" name="year" value={selectedYear} />
          <select name="member_id" required>{members.map((m) => <option value={m.id}>{m.name}</option>)}</select>
          <input type="date" name="checkin_date" required />
          <select name="mood" required><option value="1">1 - rough day</option><option value="2">2</option><option value="3" selected>3</option><option value="4">4</option><option value="5">5 - excellent</option></select>
          <input type="number" step="0.25" min="0" name="sleep_hours" placeholder="Sleep hours" />
          <input type="number" min="0" name="reading_minutes" placeholder="Reading minutes" />
          <input type="number" min="0" name="movement_minutes" placeholder="Movement minutes" />
          <input type="number" min="0" name="screen_time_minutes" placeholder="Screen time minutes" />
          <select name="social_connection"><option value="1">1 - isolated</option><option value="2">2</option><option value="3" selected>3</option><option value="4">4</option><option value="5">5 - connected</option></select>
          <textarea name="notes" rows="2" class="md:col-span-2" placeholder="Behavior, stressors, highlights"></textarea>
          <button type="submit" class="md:col-span-2 border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Check-In</button>
        </form>
      </details>
    </article>
  </section>

  <section class="mt-4 grid gap-4 lg:grid-cols-3">
    <article class="panel">
      <h2 class="panel-title">Goals</h2>
      <p class="mt-2 text-xs text-muted">{goalsCount === 0 ? 'No goals yet. Add first goal.' : `${goalsCount} goals tracked.`}</p>
      <details class="form-card mt-3" open={goalsCount === 0}>
        <summary>Add Goal</summary>
        <form method="post" action="/api/children/goal" class="mt-3 grid gap-2">
        <input type="hidden" name="year" value={selectedYear} />
        <select name="member_id" required>{members.map((m) => <option value={m.id}>{m.name}</option>)}</select>
        <input type="text" name="domain" required placeholder="Domain (school, social, habits, emotional)" />
        <input type="text" name="goal_title" required placeholder="Goal" />
        <input type="date" name="target_date" />
        <input type="number" min="0" max="100" name="progress_pct" placeholder="Progress %" />
        <select name="status"><option value="active">Active</option><option value="on_hold">On Hold</option><option value="completed">Completed</option></select>
        <textarea name="notes" rows="2" placeholder="Coach notes"></textarea>
        <button type="submit" class="border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Goal</button>
        </form>
      </details>
    </article>

    <article class="panel">
      <h2 class="panel-title">Milestones</h2>
      <p class="mt-2 text-xs text-muted">{milestonesCount === 0 ? `No milestones for ${selectedYear}.` : `${milestonesCount} milestones in ${selectedYear}.`}</p>
      <details class="form-card mt-3" open={milestonesCount === 0}>
        <summary>Add Milestone</summary>
        <form method="post" action="/api/children/milestone" class="mt-3 grid gap-2">
        <input type="hidden" name="year" value={selectedYear} />
        <select name="member_id" required>{members.map((m) => <option value={m.id}>{m.name}</option>)}</select>
        <input type="date" name="milestone_date" required />
        <input type="text" name="domain" required placeholder="Domain" />
        <input type="text" name="title" required placeholder="Milestone title" />
        <textarea name="description" rows="2" placeholder="Why this matters"></textarea>
        <button type="submit" class="border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Milestone</button>
        </form>
      </details>
    </article>

    <article class="panel">
      <h2 class="panel-title">Academics</h2>
      <p class="mt-2 text-xs text-muted">{academicsCount === 0 ? 'No academic records yet.' : `${academicsCount} recent academic entries.`}</p>
      <details class="form-card mt-3" open={academicsCount === 0}>
        <summary>Add Academic Record</summary>
        <form method="post" action="/api/children/academic" class="mt-3 grid gap-2">
        <input type="hidden" name="year" value={selectedYear} />
        <select name="member_id" required>{members.map((m) => <option value={m.id}>{m.name}</option>)}</select>
        <input type="date" name="recorded_on" required />
        <input type="text" name="term" required placeholder="Term (Fall 2026)" />
        <input type="text" name="subject" required placeholder="Subject" />
        <input type="text" name="score" placeholder="Score / grade" />
        <textarea name="teacher_note" rows="2" placeholder="Teacher note"></textarea>
        <textarea name="support_plan" rows="2" placeholder="Support plan"></textarea>
        <button type="submit" class="border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Academic Record</button>
        </form>
      </details>
    </article>
  </section>

  <section class="mt-4 grid gap-4 lg:grid-cols-2">
    <article class="panel">
      <h2 class="panel-title">Activities & Enrichment</h2>
      <p class="mt-2 text-xs text-muted">{activitiesCount === 0 ? 'No activities yet. Add first activity.' : `${activitiesCount} activities listed.`}</p>
      <details class="form-card mt-3" open={activitiesCount === 0}>
        <summary>Add Activity</summary>
        <form method="post" action="/api/children/activity" class="mt-3 grid gap-2 md:grid-cols-2">
        <input type="hidden" name="year" value={selectedYear} />
        <select name="member_id" required>{members.map((m) => <option value={m.id}>{m.name}</option>)}</select>
        <input type="text" name="category" required placeholder="Category" />
        <input type="text" name="activity_name" required placeholder="Activity" class="md:col-span-2" />
        <input type="text" name="schedule" placeholder="Schedule" />
        <input type="text" name="mentor_or_coach" placeholder="Mentor / coach" />
        <select name="status"><option value="active">Active</option><option value="paused">Paused</option><option value="completed">Completed</option></select>
        <input type="number" step="0.01" min="0" name="monthly_cost" placeholder="Monthly cost" />
        <textarea name="notes" rows="2" class="md:col-span-2" placeholder="Notes"></textarea>
        <button type="submit" class="md:col-span-2 border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Activity</button>
        </form>
      </details>

      <table class="table-report mt-4 w-full">
        <thead><tr><th>Child</th><th>Activity</th><th>Status</th></tr></thead>
        <tbody>
          {overview.activities.map((row) => (
            <tr><td>{row.member_name}</td><td>{row.activity_name}</td><td>{row.status}</td></tr>
          ))}
        </tbody>
      </table>
    </article>

    <article class="panel">
      <h2 class="panel-title">Support Network</h2>
      <p class="mt-2 text-xs text-muted">{contactsCount === 0 ? 'No support contacts yet.' : `${contactsCount} support contacts listed.`}</p>
      <details class="form-card mt-3" open={contactsCount === 0}>
        <summary>Add Support Contact</summary>
        <form method="post" action="/api/children/contact" class="mt-3 grid gap-2 md:grid-cols-2">
        <input type="hidden" name="year" value={selectedYear} />
        <select name="member_id" required>{members.map((m) => <option value={m.id}>{m.name}</option>)}</select>
        <input type="text" name="role" required placeholder="Role (teacher, pediatrician, counselor)" />
        <input type="text" name="contact_name" required placeholder="Contact name" class="md:col-span-2" />
        <input type="text" name="organization" placeholder="Organization" />
        <input type="text" name="phone" placeholder="Phone" />
        <input type="email" name="email" placeholder="Email" class="md:col-span-2" />
        <textarea name="notes" rows="2" class="md:col-span-2" placeholder="When to contact / context"></textarea>
        <button type="submit" class="md:col-span-2 border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Contact</button>
        </form>
      </details>

      <table class="table-report mt-4 w-full">
        <thead><tr><th>Child</th><th>Contact</th><th>Role</th></tr></thead>
        <tbody>
          {overview.contacts.map((row) => (
            <tr><td>{row.member_name}</td><td>{row.contact_name}</td><td>{row.role}</td></tr>
          ))}
        </tbody>
      </table>
    </article>
  </section>

  <section class="mt-4 grid gap-4 lg:grid-cols-3">
    <article class="panel lg:col-span-2 overflow-x-auto">
      <h2 class="panel-title">Goal Tracker</h2>
      <table class="table-report mt-3 w-full min-w-[820px]">
        <thead><tr><th>Child</th><th>Domain</th><th>Goal</th><th>Target</th><th class="text-right">Progress</th><th>Status</th></tr></thead>
        <tbody>
          {overview.goals.map((row) => (
            <tr>
              <td>{row.member_name}</td>
              <td>{row.domain}</td>
              <td>{row.goal_title}</td>
              <td>{row.target_date ?? '—'}</td>
              <td class="mono-num">{row.progress_pct}%</td>
              <td>{row.status}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>

    <article class="panel overflow-x-auto">
      <h2 class="panel-title">Milestone Feed ({selectedYear})</h2>
      <table class="table-report mt-3 w-full">
        <thead><tr><th>Date</th><th>Child</th><th>Milestone</th></tr></thead>
        <tbody>
          {overview.milestones.map((row) => (
            <tr>
              <td>{row.milestone_date}</td>
              <td>{row.member_name}</td>
              <td>{row.title}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>
  </section>

  <section class="panel mt-4 overflow-x-auto">
    <h2 class="panel-title">Academic Notes</h2>
    <table class="table-report mt-3 w-full min-w-[800px]">
      <thead><tr><th>Child</th><th>Term</th><th>Subject</th><th>Score</th><th>Teacher Note</th></tr></thead>
      <tbody>
        {overview.academics.map((row) => (
          <tr>
            <td>{row.member_name}</td>
            <td>{row.term}</td>
            <td>{row.subject}</td>
            <td>{row.score ?? '—'}</td>
            <td>{row.teacher_note ?? '—'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>
