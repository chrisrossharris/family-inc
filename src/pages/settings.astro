---
import BaseLayout from '@/layouts/BaseLayout.astro';

const tenantId = Astro.locals.tenantId;
const userId = Astro.locals.userId;
---

<BaseLayout title="Settings" subtitle="Workspace, profile, notifications, and permissions.">
  <section class="panel">
    <h2 class="panel-title">Session Context</h2>
    <dl class="mt-3 space-y-1 text-sm">
      <div class="flex justify-between"><dt>Workspace (tenant)</dt><dd class="font-mono">{tenantId}</dd></div>
      <div class="flex justify-between"><dt>User</dt><dd class="font-mono">{userId}</dd></div>
    </dl>
    <p class="mt-3 text-xs text-muted">Next step: connect SSO/auth provider and replace cookie-based defaults with real identities.</p>
    <div class="mt-4">
      <a class="border border-grid px-3 py-1 text-xs uppercase tracking-report hover:bg-ink hover:text-paper" href="/settings/tenant-health">
        Open Tenant Health
      </a>
    </div>
  </section>
</BaseLayout>
