---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { normalizeReportYear } from '@/lib/utils/year';
import { getHealthOverview, listFamilyMembers } from '@/lib/services/health';
import { listHealthCalendarFeeds } from '@/lib/services/integrations';

const tenantId = Astro.locals.tenantId;
const selectedYear = normalizeReportYear(Astro.url.searchParams.get('year'));
const saved = Astro.url.searchParams.get('saved');
const error = Astro.url.searchParams.get('error');
const members = await listFamilyMembers(tenantId);
const allMembers = await listFamilyMembers(tenantId, { includeInactive: true });
const overview = await getHealthOverview(tenantId, selectedYear);
const calendarFeeds = await listHealthCalendarFeeds(tenantId);
const totalEpisodes = overview.stats.symptomEntries;
const highPct = totalEpisodes > 0 ? (overview.stats.highSeverityEpisodes / totalEpisodes) * 100 : 0;
const scheduledAppointments = overview.upcomingApptList.filter((row) => row.status === 'scheduled');
const memberCount = members.length;
const symptomCount = overview.recentSymptoms.length;
const sickDayCount = overview.stats.sickDays;
const allergyCount = overview.allergies.length;
const medicationCount = overview.stats.activeMedications;
const appointmentRows = overview.upcomingApptList.map((row) => {
  const importedFromGoogle = row.provider === 'Google Calendar';
  return {
    ...row,
    eventTitle: row.appointment_type || 'Appointment',
    sourceLabel: importedFromGoogle ? 'Google Calendar import' : 'Added here',
    sourceTone: importedFromGoogle ? 'border-blue-200 bg-blue-50 text-blue-900' : 'border-grid bg-white/50 text-ink',
    providerDetail: importedFromGoogle ? row.notes?.split('\n\n').filter(Boolean)[1] ?? null : row.provider
  };
});
const confirmedAppointmentRows = appointmentRows.filter((row) => row.review_status === 'confirmed');
const reviewAppointmentRows = appointmentRows.filter((row) => row.review_status === 'needs_review');
const ignoredAppointmentRows = appointmentRows.filter((row) => row.review_status === 'ignored');
const appointmentCount = confirmedAppointmentRows.length;
const agendaMonthMap = new Map<string, typeof confirmedAppointmentRows>();
for (const row of confirmedAppointmentRows) {
  const month = row.appointment_date.slice(0, 7);
  const existing = agendaMonthMap.get(month) ?? [];
  existing.push(row);
  agendaMonthMap.set(month, existing);
}
const appointmentAgendaMonths = Array.from(agendaMonthMap.entries())
  .sort((a, b) => b[0].localeCompare(a[0]))
  .map(([month, rows]) => ({ month, appointments: rows.slice(0, 6) }));

const memberSnapshots = members.map((member) => {
  const allergyCount = overview.allergies.filter((a) => a.member_name === member.name && a.active === 1).length;
  const symptomCount = overview.recentSymptoms.filter((s) => s.member_name === member.name).length;
  const nextAppointment = scheduledAppointments.find((a) => a.member_name === member.name);
  return {
    ...member,
    allergyCount,
    symptomCount,
    nextAppointment: nextAppointment?.appointment_date ?? null
  };
});
---

<BaseLayout title="Health & Wellness" subtitle="Parent care cockpit for children, spouse, and household wellness.">
  {saved && <div class="mb-4 border border-accent/40 bg-accent/10 p-3 text-sm">Saved: {saved}</div>}
  {error && <div class="mb-4 border border-red-300 bg-red-50 p-3 text-sm text-red-900">Could not save that health entry. Check the dates and member selection, then try again.</div>}

  <section class="panel mb-4">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <p class="panel-title">Today&apos;s Parent Brief</p>
        <p class="mt-1 text-sm text-muted">Track who needs attention now, then log updates in one place.</p>
      </div>
      <div class="flex flex-wrap gap-2 text-[10px] uppercase tracking-report">
        <a class="border border-grid px-2 py-1 hover:bg-ink hover:text-paper" href="#care-calendar">Care Calendar</a>
        <a class="border border-grid px-2 py-1 hover:bg-ink hover:text-paper" href="#symptom-log">Log Symptom</a>
        <a class="border border-grid px-2 py-1 hover:bg-ink hover:text-paper" href="#appointments">Schedule Appointment</a>
        <a class="border border-grid px-2 py-1 hover:bg-ink hover:text-paper" href="#allergies">Update Allergy</a>
        <a class="border border-grid px-2 py-1 hover:bg-ink hover:text-paper" href="#medications">Update Medication</a>
      </div>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-3 xl:grid-cols-6">
    <article class="panel"><p class="panel-title">Symptom Entries ({selectedYear})</p><p class="mono-num mt-2 text-2xl">{overview.stats.symptomEntries}</p><p class="text-xs text-muted">Household total</p></article>
    <article class="panel"><p class="panel-title">High Severity (4-5)</p><p class="mono-num mt-2 text-2xl">{overview.stats.highSeverityEpisodes}</p><p class="text-xs text-muted">{highPct.toFixed(1)}% of episodes</p></article>
    <article class="panel"><p class="panel-title">Sick Days ({selectedYear})</p><p class="mono-num mt-2 text-2xl">{overview.stats.sickDays}</p></article>
    <article class="panel"><p class="panel-title">Active Allergies</p><p class="mono-num mt-2 text-2xl">{overview.stats.activeAllergies}</p></article>
    <article class="panel"><p class="panel-title">Active Medications</p><p class="mono-num mt-2 text-2xl">{overview.stats.activeMedications}</p></article>
    <article class="panel"><p class="panel-title">Upcoming Appointments</p><p class="mono-num mt-2 text-2xl">{overview.stats.upcomingAppointments}</p><p class="text-xs text-muted">Scheduled only</p></article>
  </section>

  <section class="panel mt-4 overflow-x-auto">
    <h2 class="panel-title">Family Care Snapshot</h2>
    <table class="table-report mt-3 w-full min-w-[920px]">
      <thead><tr><th>Member</th><th>Relation</th><th class="mono-num text-left">Recent Symptoms</th><th class="mono-num text-left">Active Allergies</th><th class="text-left">Next Appointment</th><th class="text-center">Status</th></tr></thead>
      <tbody>
        {memberSnapshots.map((member) => (
          <tr>
            <td class="font-medium">{member.name}</td>
            <td>{member.relation}</td>
            <td class="mono-num text-left">{member.symptomCount}</td>
            <td class="mono-num text-left">{member.allergyCount}</td>
            <td class="text-left">{member.nextAppointment ?? '—'}</td>
            <td class="text-center">
              {member.allergyCount > 0 || member.symptomCount > 2 ? (
                <span class="inline-block border border-red-300 bg-red-50 px-2 py-1 text-[10px] uppercase tracking-report text-red-900">Watch</span>
              ) : (
                <span class="inline-block border border-grid px-2 py-1 text-[10px] uppercase tracking-report">Stable</span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="mt-4 grid gap-4 lg:grid-cols-[1.1fr_0.9fr]" id="care-calendar">
    <article class="panel">
      <h2 class="panel-title">Care Calendar ({selectedYear})</h2>
      <p class="mt-2 text-xs text-muted">Month-by-month view of sick days and appointments so parents can see care load, school absences, and follow-up cadence.</p>
      <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
        {overview.careCalendar.map((month) => (
          <div class="border border-grid bg-white/40 p-3">
            <div class="flex items-center justify-between gap-3">
              <p class="panel-title">{month.month}</p>
              <p class="mono-num text-sm">{month.appointments.length + month.sickDays.length}</p>
            </div>
            <div class="mt-3 space-y-2 text-xs">
              {month.appointments.slice(0, 3).map((appointment) => (
                <div class="border border-grid p-2">
                  <p class="font-medium">{appointment.appointment_date} · {appointment.member_name ?? 'Unassigned'}</p>
                  <p class="text-muted">{appointment.provider} · {appointment.appointment_type}</p>
                </div>
              ))}
              {month.sickDays.slice(0, 3).map((day) => (
                <div class="border border-red-200 bg-red-50 p-2">
                  <p class="font-medium text-red-900">{day.start_date}{day.end_date !== day.start_date ? ` → ${day.end_date}` : ''} · {day.member_name ?? 'Unassigned'}</p>
                  <p class="text-red-800">{day.reason}</p>
                </div>
              ))}
              {month.appointments.length === 0 && month.sickDays.length === 0 && <p class="text-muted">No health events logged.</p>}
            </div>
          </div>
        ))}
      </div>
    </article>

    <article class="panel">
      <h2 class="panel-title">Shared Calendar Integration</h2>
      <p class="mt-2 text-xs text-muted">Paste the Google Calendar private iCal address for a shared calendar. Imported events land as appointments for the selected family member.</p>
      <details class="form-card mt-3" open={calendarFeeds.length === 0}>
        <summary>Add Google Calendar Feed</summary>
        <form method="post" action="/api/health/calendar-feed" class="mt-3 grid gap-2">
          <input type="hidden" name="year" value={selectedYear} />
          <input type="text" name="feed_name" required placeholder="Feed name (Family calendar, Kate appointments)" />
          <input type="url" name="ical_url" required placeholder="Google private iCal URL" />
          <select name="default_member_id" required>
            <option value="family_calendar">Family Calendar</option>
            {members.map((member) => <option value={member.id}>{member.name}</option>)}
          </select>
          <label class="inline-flex items-center gap-2 text-xs"><input type="checkbox" name="active" value="1" checked /> Active</label>
          <button type="submit" class="border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Feed</button>
        </form>
      </details>
      <div class="mt-3 space-y-3">
        {calendarFeeds.length === 0 && <div class="border border-grid p-3 text-xs text-muted">No Google Calendar feeds connected yet.</div>}
        {calendarFeeds.map((feed) => (
          <div class="border border-grid p-3 text-xs">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <div>
                <p class="font-medium text-ink">{feed.feed_name}</p>
                <p class="text-muted">{feed.default_member_name ?? 'No member assigned'} · {feed.last_synced_at ?? 'Never synced'}</p>
              </div>
              <div class="flex flex-wrap gap-2">
                <form method="post" action="/api/health/calendar-sync">
                  <input type="hidden" name="year" value={selectedYear} />
                  <input type="hidden" name="feed_id" value={feed.id} />
                  <button type="submit" class="border border-grid px-2 py-1 text-[10px] uppercase tracking-report hover:bg-ink hover:text-paper">Sync Now</button>
                </form>
                <form method="post" action="/api/health/calendar-feed">
                  <input type="hidden" name="year" value={selectedYear} />
                  <input type="hidden" name="id" value={feed.id} />
                  <input type="hidden" name="mode" value="delete" />
                  <button type="submit" class="border border-red-500 px-2 py-1 text-[10px] uppercase tracking-report text-red-700 hover:bg-red-600 hover:text-paper">Delete</button>
                </form>
              </div>
            </div>
          </div>
        ))}
      </div>
    </article>
  </section>

  <section class="mt-4 grid items-start gap-4 lg:grid-cols-2">
    <article class="panel min-w-0" id="members">
      <h2 class="panel-title">Family Members</h2>
      <p class="mt-2 text-xs text-muted">{memberCount === 0 ? 'No family members yet. Add your first member.' : `${memberCount} active family member${memberCount === 1 ? '' : 's'}.`}</p>
      <details class="form-card mt-3" open={memberCount === 0}>
        <summary>Add Family Member</summary>
        <form method="post" action="/api/health/member" class="mt-3 grid gap-2 md:grid-cols-2">
          <input type="hidden" name="year" value={selectedYear} />
          <input type="text" name="name" required placeholder="Name" />
          <input type="text" name="relation" required placeholder="Relation (self, spouse, child)" />
          <input type="date" name="birth_date" />
          <input type="text" name="notes" placeholder="Health notes" />
          <label class="inline-flex items-center gap-2 text-xs"><input type="checkbox" name="is_active" value="1" checked /> Active</label>
          <button type="submit" class="border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Add Member</button>
        </form>
      </details>
      <div class="overflow-x-auto">
        <table class="table-report mt-4 w-full min-w-[860px]">
          <thead><tr><th>Name</th><th>Relation</th><th>Birth Date</th><th>Notes</th><th>Active</th><th>Edit</th></tr></thead>
          <tbody>
            {allMembers.length === 0 && <tr><td colspan="6" class="text-xs text-muted">No members yet.</td></tr>}
            {allMembers.map((member) => (
              <tr>
                <td>
                  <input form={`member-edit-${member.id}`} type="text" name="name" required value={member.name} class="text-xs" />
                </td>
                <td>
                  <input form={`member-edit-${member.id}`} type="text" name="relation" required value={member.relation} class="text-xs" />
                </td>
                <td>
                  <input form={`member-edit-${member.id}`} type="date" name="birth_date" value={member.birth_date ?? ''} class="text-xs" />
                </td>
                <td>
                  <input form={`member-edit-${member.id}`} type="text" name="notes" value={member.notes ?? ''} class="text-xs" />
                </td>
                <td>
                  <label class="inline-flex items-center gap-2 text-xs">
                    <input form={`member-edit-${member.id}`} type="checkbox" name="is_active" value="1" checked={member.is_active === 1} />
                    {member.is_active === 1 ? 'Yes' : 'No'}
                  </label>
                </td>
                <td>
                  <button form={`member-edit-${member.id}`} type="submit" class="border border-grid px-2 py-1 text-[10px] uppercase tracking-report hover:bg-ink hover:text-paper">Save</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {allMembers.map((member) => (
        <form id={`member-edit-${member.id}`} method="post" action="/api/health/member" class="hidden">
          <input type="hidden" name="year" value={selectedYear} />
          <input type="hidden" name="id" value={member.id} />
        </form>
      ))}
    </article>

    <article class="panel min-w-0" id="symptom-log">
      <h2 class="panel-title">Log Symptom Episode (Child/Spouse/Self)</h2>
      <p class="mt-2 text-xs text-muted">{symptomCount === 0 ? 'No symptom entries yet.' : `${symptomCount} recent symptom entries shown.`}</p>
      <details class="form-card mt-3" open={symptomCount === 0}>
        <summary>Add Symptom Log</summary>
        <form method="post" action="/api/health/symptom" class="mt-3 grid gap-2 md:grid-cols-2">
          <input type="hidden" name="year" value={selectedYear} />
          <select name="member_id"><option value="">Unassigned</option>{members.map((m) => <option value={m.id}>{m.name}</option>)}</select>
          <input type="date" name="occurred_on" required />
          <input type="text" name="symptom" required placeholder="Symptom (headache, rash, cough)" class="md:col-span-2" />
          <select name="severity" required><option value="1">1 - mild</option><option value="2">2</option><option value="3" selected>3</option><option value="4">4</option><option value="5">5 - severe</option></select>
          <input type="number" step="0.25" min="0" name="duration_hours" placeholder="Duration hours" />
          <input type="text" name="trigger" placeholder="Possible trigger" class="md:col-span-2" />
          <textarea name="notes" rows="2" placeholder="Context / interventions" class="md:col-span-2"></textarea>
          <button type="submit" class="md:col-span-2 border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Symptom Log</button>
        </form>
      </details>
    </article>
  </section>

  <section class="mt-4 grid gap-4 lg:grid-cols-3">
    <article class="panel" id="sick-days">
      <h2 class="panel-title">Sick Day Log (School/Work Impact)</h2>
      <details class="form-card mt-3" open={sickDayCount === 0}>
        <summary>Add Sick Day</summary>
        <form method="post" action="/api/health/sick-day" class="mt-3 grid gap-2">
        <input type="hidden" name="year" value={selectedYear} />
        <select name="member_id" required>{members.map((m) => <option value={m.id}>{m.name}</option>)}</select>
        <input type="date" name="start_date" required />
        <input type="date" name="end_date" required />
        <input type="text" name="reason" required placeholder="Reason" />
        <label class="inline-flex items-center gap-2 text-xs"><input type="checkbox" name="fever" value="1" /> Fever present</label>
        <label class="inline-flex items-center gap-2 text-xs"><input type="checkbox" name="school_work_missed" value="1" checked /> Missed school/work</label>
        <textarea name="notes" rows="2" placeholder="Notes"></textarea>
        <button type="submit" class="border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Sick Day</button>
        </form>
      </details>
      <table class="table-report mt-4 w-full">
        <thead><tr><th>Dates</th><th>Member</th><th>Reason</th><th>Missed</th><th>Edit</th><th>Delete</th></tr></thead>
        <tbody>
          {overview.sickDayList.length === 0 && <tr><td colspan="6" class="text-xs text-muted">No sick days logged yet.</td></tr>}
          {overview.sickDayList.slice(0, 10).map((row) => (
            <tr>
              <td>
                <div class="edit-date-range">
                  <input form={`sickday-edit-${row.id}`} type="date" name="start_date" value={row.start_date} class="text-xs" />
                  <span class="text-xs text-muted">→</span>
                  <input form={`sickday-edit-${row.id}`} type="date" name="end_date" value={row.end_date} class="text-xs" />
                </div>
              </td>
              <td>
                <select form={`sickday-edit-${row.id}`} name="member_id" class="text-xs">
                  {allMembers.map((member) => <option value={member.id} selected={member.id === row.member_id}>{member.name}</option>)}
                </select>
              </td>
              <td><input form={`sickday-edit-${row.id}`} type="text" name="reason" value={row.reason} class="text-xs" /></td>
              <td>
                <label class="inline-flex items-center gap-2 text-xs">
                  <input form={`sickday-edit-${row.id}`} type="checkbox" name="school_work_missed" value="1" checked={row.school_work_missed === 1} />
                  {row.school_work_missed === 1 ? 'Yes' : 'No'}
                </label>
                <input form={`sickday-edit-${row.id}`} type="hidden" name="fever" value={row.fever ? '1' : ''} />
                <input form={`sickday-edit-${row.id}`} type="hidden" name="notes" value={row.notes ?? ''} />
              </td>
              <td><button form={`sickday-edit-${row.id}`} type="submit" class="border border-grid px-2 py-1 text-[10px] uppercase tracking-report hover:bg-ink hover:text-paper">Save</button></td>
              <td><button form={`sickday-delete-${row.id}`} type="submit" class="border border-red-500 px-2 py-1 text-[10px] uppercase tracking-report text-red-700 hover:bg-red-600 hover:text-paper">Delete</button></td>
            </tr>
          ))}
        </tbody>
      </table>
      {overview.sickDayList.slice(0, 10).map((row) => (
        <>
          <form id={`sickday-edit-${row.id}`} method="post" action="/api/health/sick-day" class="hidden">
            <input type="hidden" name="year" value={selectedYear} />
            <input type="hidden" name="id" value={row.id} />
          </form>
          <form id={`sickday-delete-${row.id}`} method="post" action="/api/health/sick-day" class="hidden">
            <input type="hidden" name="year" value={selectedYear} />
            <input type="hidden" name="id" value={row.id} />
            <input type="hidden" name="mode" value="delete" />
          </form>
        </>
      ))}
    </article>

    <article class="panel" id="allergies">
      <h2 class="panel-title">Allergy Profile & Emergency Prep</h2>
      <p class="mt-2 text-xs text-muted">{allergyCount === 0 ? 'No allergy profile data yet.' : `${allergyCount} allergy entries tracked.`}</p>
      <details class="form-card mt-3" open={allergyCount === 0}>
        <summary>Add Allergy</summary>
        <form method="post" action="/api/health/allergy" class="mt-3 grid gap-2">
        <input type="hidden" name="year" value={selectedYear} />
        <select name="member_id" required>{members.map((m) => <option value={m.id}>{m.name}</option>)}</select>
        <input type="text" name="allergen" required placeholder="Allergen" />
        <input type="text" name="reaction" required placeholder="Reaction" />
        <select name="severity" required><option value="1">1 - mild</option><option value="2">2</option><option value="3">3</option><option value="4">4</option><option value="5">5 - severe</option></select>
        <label class="inline-flex items-center gap-2 text-xs"><input type="checkbox" name="has_epinephrine" value="1" /> Epinephrine available</label>
        <textarea name="notes" rows="2" placeholder="Avoidance / plan"></textarea>
        <button type="submit" class="border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Allergy</button>
        </form>
      </details>
    </article>

    <article class="panel" id="medications">
      <h2 class="panel-title">Medication Tracker</h2>
      <details class="form-card mt-3" open={medicationCount === 0}>
        <summary>Add Medication</summary>
        <form method="post" action="/api/health/medication" class="mt-3 grid gap-2">
        <input type="hidden" name="year" value={selectedYear} />
        <select name="member_id" required>{members.map((m) => <option value={m.id}>{m.name}</option>)}</select>
        <input type="text" name="medication_name" required placeholder="Medication" />
        <input type="text" name="dosage" required placeholder="Dosage" />
        <input type="text" name="frequency" required placeholder="Frequency" />
        <input type="date" name="start_date" required />
        <input type="date" name="end_date" placeholder="End date" />
        <input type="text" name="prescribed_by" placeholder="Prescriber" />
        <textarea name="notes" rows="2" placeholder="Instructions / side effects"></textarea>
        <button type="submit" class="border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Medication</button>
        </form>
      </details>
    </article>
  </section>

  <section class="mt-4">
    <article class="panel" id="appointments">
      <h2 class="panel-title">Appointments</h2>
      <p class="mt-2 text-xs text-muted">Use this as a household agenda. Confirm imported Google events that are true appointments, and ignore the rest.</p>
      <details class="form-card mt-3" open={appointmentCount === 0}>
        <summary>Add Appointment</summary>
        <form method="post" action="/api/health/appointment" class="mt-3 grid gap-2 md:grid-cols-2">
        <input type="hidden" name="year" value={selectedYear} />
        <select name="member_id" required>{members.map((m) => <option value={m.id}>{m.name}</option>)}</select>
        <input type="date" name="appointment_date" required />
        <input type="text" name="provider" required placeholder="Provider" />
        <input type="text" name="appointment_type" required placeholder="Visit type" />
        <select name="status"><option value="scheduled">Scheduled</option><option value="completed">Completed</option><option value="cancelled">Cancelled</option></select>
        <input type="date" name="follow_up_date" placeholder="Follow-up date" />
        <textarea name="notes" rows="2" class="md:col-span-2" placeholder="Agenda / prep"></textarea>
        <button type="submit" class="md:col-span-2 border border-ink bg-ink px-3 py-2 text-xs uppercase tracking-report text-paper">Save Appointment</button>
        </form>
      </details>
      <div class="mt-4 grid gap-4 xl:grid-cols-[0.95fr_1.05fr]">
        <div class="border border-grid p-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <h3 class="panel-title">Calendar Agenda</h3>
              <p class="mt-1 text-xs text-muted">Confirmed appointments only. This keeps the Family Inc view clean while Google remains the full calendar system.</p>
            </div>
            <div class="text-xs text-muted">{appointmentCount} confirmed appointment{appointmentCount === 1 ? '' : 's'}</div>
          </div>
          <div class="mt-4 grid gap-3 md:grid-cols-2">
            {appointmentAgendaMonths.length === 0 && <div class="border border-grid p-3 text-xs text-muted">No appointments on the board yet.</div>}
            {appointmentAgendaMonths.map((month) => (
              <div class="border border-grid bg-white/40 p-3">
                <div class="flex items-center justify-between gap-3">
                  <p class="panel-title">{month.month}</p>
                  <p class="mono-num text-sm">{month.appointments.length}</p>
                </div>
                <div class="mt-3 space-y-2">
                  {month.appointments.map((appointment) => {
                    const importedFromGoogle = appointment.provider === 'Google Calendar';
                    const locationHint = importedFromGoogle ? appointment.notes?.split('\n\n').filter(Boolean)[1] ?? null : null;
                    return (
                      <div class="border border-grid p-2 text-xs">
                        <div class="flex items-start justify-between gap-2">
                          <div>
                            <p class="font-medium text-ink">{appointment.appointment_type}</p>
                            <p class="text-muted">{appointment.appointment_date} · {appointment.member_name ?? 'Unassigned'}</p>
                          </div>
                          <span class:list={['inline-block whitespace-nowrap border px-2 py-1 text-[10px] uppercase tracking-report', importedFromGoogle ? 'border-blue-200 bg-blue-50 text-blue-900' : 'border-grid bg-white/60 text-ink']}>
                            {importedFromGoogle ? 'Google' : 'Manual'}
                          </span>
                        </div>
                        <p class="mt-2 text-muted">{importedFromGoogle ? 'Imported from Google Calendar' : appointment.provider}</p>
                        {locationHint && <p class="text-muted">{locationHint}</p>}
                      </div>
                    );
                  })}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="border border-grid p-4 overflow-x-auto">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <h3 class="panel-title">Appointment Log</h3>
              <p class="mt-1 text-xs text-muted">Most recent confirmed appointments first. Google imports only show up here after you confirm they are real appointments.</p>
            </div>
          </div>
          <table class="table-report mt-4 w-full min-w-[1080px]">
            <thead><tr><th>Date</th><th>Event</th><th>Member</th><th>Source</th><th>Status</th><th>Edit</th><th>Delete</th></tr></thead>
            <tbody>
              {confirmedAppointmentRows.length === 0 && <tr><td colspan="7" class="text-xs text-muted">No confirmed appointments yet.</td></tr>}
              {confirmedAppointmentRows.map((row) => (
                <tr>
                  <td><input form={`appointment-edit-${row.id}`} type="date" name="appointment_date" value={row.appointment_date} class="text-xs" /></td>
                  <td class="min-w-[220px]">
                    <input form={`appointment-edit-${row.id}`} type="text" name="appointment_type" value={row.appointment_type} class="text-xs" />
                    {row.follow_up_date && <p class="mt-1 text-[10px] uppercase tracking-report text-muted">Follow-up {row.follow_up_date}</p>}
                  </td>
                  <td>
                    <select form={`appointment-edit-${row.id}`} name="member_id" class="text-xs">
                      {allMembers.map((member) => <option value={member.id} selected={member.id === row.member_id}>{member.name}</option>)}
                    </select>
                  </td>
                  <td class="min-w-[280px]">
                    <input form={`appointment-edit-${row.id}`} type="text" name="provider" value={row.provider} class="text-xs" />
                    <div class="mt-2 flex items-center gap-2">
                      <span class:list={['inline-block border px-2 py-1 text-[10px] uppercase tracking-report', row.sourceTone]}>{row.sourceLabel}</span>
                    </div>
                    {row.providerDetail && <p class="mt-2 text-[11px] text-muted">{row.providerDetail}</p>}
                    <textarea form={`appointment-edit-${row.id}`} name="notes" rows="2" class="mt-2 text-xs" placeholder="Agenda / prep / imported details">{row.notes ?? ''}</textarea>
                    <input form={`appointment-edit-${row.id}`} type="hidden" name="follow_up_date" value={row.follow_up_date ?? ''} />
                  </td>
                  <td>
                    <select form={`appointment-edit-${row.id}`} name="status" class="text-xs">
                      <option value="scheduled" selected={row.status === 'scheduled'}>scheduled</option>
                      <option value="completed" selected={row.status === 'completed'}>completed</option>
                      <option value="cancelled" selected={row.status === 'cancelled'}>cancelled</option>
                    </select>
                  </td>
                  <td><button form={`appointment-edit-${row.id}`} type="submit" class="border border-grid px-2 py-1 text-[10px] uppercase tracking-report hover:bg-ink hover:text-paper">Save</button></td>
                  <td><button form={`appointment-delete-${row.id}`} type="submit" class="border border-red-500 px-2 py-1 text-[10px] uppercase tracking-report text-red-700 hover:bg-red-600 hover:text-paper">Delete</button></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <div class="mt-4 grid gap-4 xl:grid-cols-[1fr_auto]">
        <div class="border border-grid p-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <h3 class="panel-title">Imported Calendar Review</h3>
              <p class="mt-1 text-xs text-muted">These came from Google Calendar. Confirm the real appointments and ignore the rest.</p>
            </div>
            <div class="text-xs text-muted">{reviewAppointmentRows.length} waiting · {ignoredAppointmentRows.length} ignored</div>
          </div>
          <div class="mt-4 space-y-3">
            {reviewAppointmentRows.length === 0 && <div class="border border-grid p-3 text-xs text-muted">No Google events waiting for review.</div>}
            {reviewAppointmentRows.map((row) => (
              <div class="border border-grid p-3">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-2">
                      <p class="font-medium text-ink">{row.eventTitle}</p>
                      <span class="inline-block border border-blue-200 bg-blue-50 px-2 py-1 text-[10px] uppercase tracking-report text-blue-900">Google import</span>
                    </div>
                    <p class="mt-1 text-xs text-muted">{row.appointment_date} · {row.member_name ?? 'Unassigned'}</p>
                    {row.notes && <p class="mt-2 text-xs text-muted">{row.notes}</p>}
                  </div>
                  <div class="flex flex-wrap gap-2">
                    <button form={`appointment-confirm-${row.id}`} type="submit" class="border border-ink bg-ink px-3 py-2 text-[10px] uppercase tracking-report text-paper">Confirm Appointment</button>
                    <button form={`appointment-ignore-${row.id}`} type="submit" class="border border-grid px-3 py-2 text-[10px] uppercase tracking-report hover:bg-ink hover:text-paper">Ignore</button>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
      {appointmentRows.map((row) => (
        <>
          <form id={`appointment-edit-${row.id}`} method="post" action="/api/health/appointment" class="hidden">
            <input type="hidden" name="year" value={selectedYear} />
            <input type="hidden" name="id" value={row.id} />
          </form>
          <form id={`appointment-delete-${row.id}`} method="post" action="/api/health/appointment" class="hidden">
            <input type="hidden" name="year" value={selectedYear} />
            <input type="hidden" name="id" value={row.id} />
            <input type="hidden" name="mode" value="delete" />
          </form>
          <form id={`appointment-confirm-${row.id}`} method="post" action="/api/health/appointment" class="hidden">
            <input type="hidden" name="year" value={selectedYear} />
            <input type="hidden" name="id" value={row.id} />
            <input type="hidden" name="mode" value="review" />
            <input type="hidden" name="review_status" value="confirmed" />
          </form>
          <form id={`appointment-ignore-${row.id}`} method="post" action="/api/health/appointment" class="hidden">
            <input type="hidden" name="year" value={selectedYear} />
            <input type="hidden" name="id" value={row.id} />
            <input type="hidden" name="mode" value="review" />
            <input type="hidden" name="review_status" value="ignored" />
          </form>
        </>
      ))}
    </article>
  </section>

  <section class="mt-4 grid gap-4 lg:grid-cols-2">
    <article class="panel">
      <h2 class="panel-title">Recent Symptom Feed</h2>
      <table class="table-report mt-3 w-full">
        <thead><tr><th>Date</th><th>Member</th><th>Symptom</th><th class="text-right">Severity</th></tr></thead>
        <tbody>
          {overview.recentSymptoms.map((row) => (
            <tr>
              <td>{row.occurred_on}</td>
              <td>{row.member_name ?? '—'}</td>
              <td>{row.symptom}</td>
              <td class="mono-num">{row.severity}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h3 class="panel-title mt-5">Allergy Watchlist</h3>
      <table class="table-report mt-3 w-full">
        <thead><tr><th>Member</th><th>Allergen</th><th>Reaction</th><th class="text-right">Severity</th></tr></thead>
        <tbody>
          {overview.allergies.map((row) => (
            <tr>
              <td>{row.member_name ?? '—'}</td>
              <td>{row.allergen}</td>
              <td>{row.reaction}</td>
              <td class="mono-num">{row.severity}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </article>
  </section>
</BaseLayout>
