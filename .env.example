# Neon Postgres (recommended production default)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: unpooled admin/migration URL (Neon direct endpoint)
# NETLIFY_DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname?sslmode=require

# Optional local SQLite/libSQL mode
# DATABASE_URL=file:./data/family-ledger.sqlite

# Optional Turso mode
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token

# Clerk auth
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key
CLERK_SECRET_KEY=sk_test_your_key

# Invite email (Resend)
# RESEND_API_KEY=re_...
# INVITE_FROM_EMAIL=Family Inc <onboarding@yourdomain.com>
# APP_BASE_URL=http://localhost:4321

# Background import worker secret (recommended for production)
IMPORT_JOB_SECRET=replace_with_random_secret

# Stripe
# STRIPE_SECRET_KEY=sk_test_or_live
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_FAMILY_PLUS=price_...
# STRIPE_PRICE_FAMILY_PRO=price_...
# REQUIRE_STRIPE_BILLING=1
# Optional aliases also supported:
# STRIPE_PRICE_ID_FAMILY_PLUS=price_...
# STRIPE_PRICE_ID_FAMILY_PRO=price_...

# Optional override for migration runner only
# MIGRATIONS_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

REPORT_YEAR=2025
